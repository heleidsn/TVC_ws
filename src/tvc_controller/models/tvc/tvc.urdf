<?xml version="1.0"?>
<!-- Simplified TVC visual model for RViz (primitive shapes, matches Gazebo tvc model). -->
<robot name="tvc">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.052"/>
      </geometry>
      <material name="body_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
  </link>

  <link name="top_cone">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.052"/>
      </geometry>
      <material name="cone_grey">
        <color rgba="0.45 0.45 0.45 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="top_cone_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_cone"/>
    <origin xyz="0 0 0.55" rpy="0 0 0"/>
  </joint>

  <link name="gimbal_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
      <material name="gimbal_dark">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="base_to_gimbal_mount" type="fixed">
    <parent link="base_link"/>
    <child link="gimbal_mount"/>
    <origin xyz="0 0 -0.52" rpy="0 0 0"/>
  </joint>

  <link name="servo0_roll">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.06 0.03"/>
      </geometry>
      <material name="servo0_red">
        <color rgba="0.9 0.3 0.3 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="servo0_roll_joint" type="revolute">
    <parent link="gimbal_mount"/>
    <child link="servo0_roll"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.25" upper="0.25" effort="1.0" velocity="10.0"/>
  </joint>

  <link name="servo1_pitch">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.02 0.03"/>
      </geometry>
      <material name="servo1_green">
        <color rgba="0.3 0.9 0.3 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="servo1_pitch_joint" type="revolute">
    <parent link="servo0_roll"/>
    <child link="servo1_pitch"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.25" upper="0.25" effort="1.0" velocity="10.0"/>
  </joint>

  <link name="motor_housing">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.008"/>
      </geometry>
      <material name="motor_dark">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="pitch_to_motor" type="fixed">
    <parent link="servo1_pitch"/>
    <child link="motor_housing"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="prop_upper">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.02 0.002"/>
      </geometry>
      <material name="prop_upper_blue">
        <color rgba="0.2 0.2 0.9 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="motor1_joint" type="continuous">
    <parent link="motor_housing"/>
    <child link="prop_upper"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="prop_lower">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.02 0.002"/>
      </geometry>
      <material name="prop_lower_red">
        <color rgba="0.9 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="motor2_joint" type="continuous">
    <parent link="motor_housing"/>
    <child link="prop_lower"/>
    <origin xyz="0 0 -0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Landing legs (fixed, simplified) -->
  <link name="landing_leg_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.005"/>
      </geometry>
      <material name="leg_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="leg_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_1"/>
    <origin xyz="0.18 0 -0.6216" rpy="0 -0.785398 0"/>
  </joint>

  <link name="landing_leg_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.005"/>
      </geometry>
      <material name="leg_grey"/>
    </visual>
  </link>
  <joint name="leg_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_2"/>
    <origin xyz="0 0.18 -0.6216" rpy="0.785398 0 0"/>
  </joint>

  <link name="landing_leg_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.005"/>
      </geometry>
      <material name="leg_grey"/>
    </visual>
  </link>
  <joint name="leg_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_3"/>
    <origin xyz="-0.18 0 -0.6216" rpy="0 0.785398 0"/>
  </joint>

  <link name="landing_leg_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.005"/>
      </geometry>
      <material name="leg_grey"/>
    </visual>
  </link>
  <joint name="leg_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_4"/>
    <origin xyz="0 -0.18 -0.6216" rpy="-0.785398 0 0"/>
  </joint>
</robot>
